# notes-dash configuration
# Copy to .env (or .env.tpl with op:// references) and fill in.

# Required — the GitHub repo holding your published notes (and a .ledger.json at the root).
NOTES_REPO_SLUG=your-username/your-notes-content-repo

# For private repos: a fine-grained PAT with "Contents: read" on the repo above.
# Public repos can leave both empty.
GITHUB_TOKEN=
GITHUB_USERNAME=

# Required — the public URL where notes are served.
# Each note is linked as ${NOTES_BASE_URL}/<slug>/
NOTES_BASE_URL=https://notes.example.com

# Optional — display title in the masthead. Defaults to the host of NOTES_BASE_URL.
# Tip: include a "." to get the italic accent treatment on the first dot.
NOTES_SITE_TITLE=notes.example.com

# Optional — if set, each row shows a "copy" button that puts this command on the
# clipboard with {slug} replaced. Useful for self-hosted publish/unpublish flows.
# NOTES_UNPUBLISH_CMD=ssh me@home 'cd ~/notes && ./unpublish.sh --slug={slug}'

# Optional — small text in the footer right (e.g. "home.local:8181").
NOTES_FOOTER_HOST=

# Optional — path to the ledger JSON inside the repo (default: .ledger.json)
# NOTES_LEDGER_PATH=.ledger.json

# Optional — host port (default 8181). Used by docker-compose.yml.
# PORT=8181
